    "type": "magento-module",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Luiz Santos",
            "email": "luiz@ultradev.com.br",
            "homepage": "https://ultraeletronicos.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "magento-hackathon/magento-composer-installer": "*"
    },
    "extra": {
        "map": [
            ["app/code/community/UltraDev/SuggestedProducts", "app/code/community/UltraDev/SuggestedProducts"],
            ["app/design/frontend/base/default/layout/ultradev_suggestedproducts.xml", "app/design/frontend/base/default/layout/ultradev_suggestedproducts.xml"],
